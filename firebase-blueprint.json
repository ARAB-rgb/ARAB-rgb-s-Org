    "User": {
      "title": "User",
      "description": "Authorized employee profile with fine-grained visual permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee", "supervisor"] },
        "worker_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "perms": {
          "type": "object",
          "properties": {
            "region": { "type": "string" },
            "installmentsView": { "type": "boolean" },
            "installmentsAdd": { "type": "boolean" },
            "installmentsEdit": { "type": "boolean" },
            "installmentsDelete": { "type": "boolean" },
            "quotes": { "type": "boolean" },
            "receipts": { "type": "boolean" },
            "payments": { "type": "boolean" },
            "expenses": { "type": "boolean" },
            "treasury": { "type": "boolean" },
            "projects": { "type": "boolean" },
            "workers": { "type": "boolean" },
            "users": { "type": "boolean" },
            "sessions": { "type": "boolean" },
            "print": { "type": "boolean" },
            "dashTopCards": { "type": "boolean" },
            "dashCollection": { "type": "boolean" },
            "dashPulse": { "type": "boolean" },
            "dashLateClients": { "type": "boolean" },
            "dashLastReceipts": { "type": "boolean" },
            "dashUpcomingPaid": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "name", "code", "role"]
    },
    "Installment": {
      "title": "Installment",
      "description": "Installment contracts detailing total amounts, paid schedules, and target regions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "identity": { "type": "string" },
        "nationality": { "type": "string" },
        "phone": { "type": "string" },
        "no": { "type": "string" },
        "amount": { "type": "number" },
        "paid": { "type": "number" },
        "remaining": { "type": "number" },
        "type": { "type": "string", "enum": ["daily"] },
        "start_date": { "type": "string" },
        "end_date": { "type": "string" },
        "next_due": { "type": "string" },
        "periods": { "type": "number" },
        "installment": { "type": "number" },
        "discount": { "type": "number" },
        "after_discount": { "type": "number" },
        "project": { "type": "string" },
        "workplace": { "type": "string" },
        "guarantor": { "type": "string" },
        "status": { "type": "string", "enum": ["منتظم", "متأخر", "متعثر", "مكتمل"] },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "client", "identity", "phone", "no", "amount", "paid", "remaining"]
    },
    "Quote": {
      "title": "Quote",
