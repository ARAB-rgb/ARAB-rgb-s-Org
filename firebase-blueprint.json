        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["جديد", "مرسل", "مقبول", "مرفوض"] },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "no", "client", "amount"]
